{
  // ensure comments and trailing commas are supported
  "$schema": "../../schemas/quality.schema.json",
  "stages": {},
  "profiles": {
    "local": {
      "pipeline": [
        {
          "id": "sample:command",
          "type": "command",
          "overrides": {
            "commands": [
              {
                "command": ["echo", "hello"],
                "label": "hello"
              }
            ]
          }
        }
      ],
      "reporters": ["summary"]
    }
  }
}
