{
  "$schema": "../../../schemas/qualityrc.schema.json",
  "ignore": ["fixture-root-ignore/**"],
  "profiles": {
    "local": {
      "pipeline": [
        {
          "id": "stub:base",
          "type": "stub",
          "overrides": { "shouldFail": false }
        }
      ],
      "reporters": ["summary"],
      "hooks": {
        "onStart": ["echo start"],
        "onComplete": ["echo done"],
        "onSuccess": [],
        "onStageFail": {}
      }
    },
    "command": {
      "pipeline": [
        {
          "id": "command:stage",
          "type": "command",
          "overrides": {
            "commands": ["echo command"],
            "abortPipelineOnFailure": false
          }
        }
      ]
    },
    "ci": {
      "extends": "local",
      "reporters": ["summary", ["json", { "path": "reports/quality-ci.json" }]]
    }
  }
}
